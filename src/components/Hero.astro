<section class="hero">
	<div class="hero-content">
		<h1>非典型字幕组</h1>
		<p class="tagline">专业字幕翻译团队，连接世界与您的视听体验</p>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		flex: 1;
		height:20vh;
		padding: var(--space-24) var(--space-8) var(--space-16);
		overflow: hidden;
		background:
			radial-gradient(ellipse 80% 50% at 50% -20%, rgba(37, 99, 235, 0.15), transparent),
			radial-gradient(ellipse 60% 40% at 80% 80%, rgba(59, 130, 246, 0.08), transparent),
			linear-gradient(180deg, var(--sl-color-bg) 0%, var(--sl-color-bg) 100%);
	}

	.hero-content {
		margin: 0 auto;
		width: 100%;
	}

	.hero h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--sl-color-text);
		margin-bottom: var(--space-6);
	}

	.tagline {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: var(--sl-color-text-muted);
		max-width: 440px;
		margin: 0 auto var(--space-10);
		line-height: 1.6;
	}

</style>
