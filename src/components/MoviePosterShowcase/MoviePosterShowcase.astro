---
/**
 * 欧美剧集海报墙组件 - 自适应填充版
 * - 仅展示欧美热门剧集，严格过滤中日韩等地区内容
 * - 根据视窗尺寸动态计算海报数量，完全填充页面空间
 * - CSS Grid auto-fill 响应式 + JS 动态数量计算
 * - 数据池机制：预加载超额数据，按需渲染
 * - ResizeObserver 实时响应窗口变化
 * - IntersectionObserver 懒加载 + 低质量占位图渐进式加载
 */
---

<section id="poster-wall" class="poster-wall" aria-label="欧美剧集海报展示">
	<div class="wall-container">
		<div class="poster-grid" id="poster-grid"></div>
		<div class="wall-error" id="wall-error" style="display: none;">
			<div class="error-content">
				<svg class="error-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="12" cy="12" r="10"/>
					<line x1="12" y1="8" x2="12" y2="12"/>
					<line x1="12" y1="16" x2="12.01" y2="16"/>
				</svg>
				<p class="error-text">加载海报时出现问题</p>
				<button class="retry-btn" id="retry-btn">重新加载</button>
			</div>
		</div>
	</div>
</section>

<script>
	import {
		getRandomPopularTVShows,
		fetchAdditionalTVShows,
		getPosterUrl,
		getLowQualityPosterUrl,
		posterWallCache,
		preloadImages,
	} from '../../lib/tmdb';
	import type { TVShow } from '../../lib/tmdb';
	import { fuzzyFindWorkSlug, getTranslatedTmdbIds } from '../../lib/worksMapping';

	const CONFIG = {
		posterAspectRatio: 2 / 3,
		silentRefreshDelay: 3000,
		lazyLoadRootMargin: '400px 0px',
		entranceStaggerMs: 20,
		entranceMaxDelay: 500,
		resizeDebounceMs: 200,
		fetchBuffer: 12,
		initialMaxPages: 5,
	};

	let allShows: TVShow[] = [];
	let displayedCount = 0;
	let isLoading = false;
	let isRefreshing = false;
	let isFetchingMore = false;
	let intersectionObserver: IntersectionObserver | null = null;
	let resizeObserver: ResizeObserver | null = null;
	let posterUrlMap: Record<number, string | null> = {};
	let translatedTmdbIds: Set<number> = new Set();
	let currentTargetCount = 0;

	const gridEl = document.getElementById('poster-grid') as HTMLElement;
	const errorEl = document.getElementById('wall-error') as HTMLElement;
	const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

	function escapeHtml(str: string): string {
		const div = document.createElement('div');
		div.textContent = str;
		return div.innerHTML;
	}

	function isTranslatedWork(show: TVShow): boolean {
		if (translatedTmdbIds.has(show.id)) return true;
		const title = show.name || show.originalName || '';
		return fuzzyFindWorkSlug(title) !== null;
	}

	// ==================== 自适应数量计算 ====================

	function getResponsiveMinWidth(): number {
		const w = window.innerWidth;
		if (w >= 1200) return 140;
		if (w >= 768) return 100;
		if (w >= 480) return 90;
		return 80;
	}

	function getResponsiveGap(): number {
		const w = window.innerWidth;
		if (w >= 768) return 8;
		if (w >= 480) return 6;
		return 4;
	}

	function estimateTargetCount(): number {
		const containerWidth = gridEl.clientWidth || window.innerWidth;
		const viewportHeight = window.innerHeight;
		const gap = getResponsiveGap();
		const padding = gap * 2;
		const availableWidth = containerWidth - padding;
		const minItemWidth = getResponsiveMinWidth();

		const columns = Math.max(1, Math.floor((availableWidth + gap) / (minItemWidth + gap)));
		const itemWidth = (availableWidth - (columns - 1) * gap) / columns;
		const itemHeight = itemWidth * (1 / CONFIG.posterAspectRatio);
		const rows = Math.max(1, Math.ceil(viewportHeight / (itemHeight + gap)));

		return columns * rows;
	}

	function measureActualTargetCount(): number {
		const items = gridEl.querySelectorAll('.poster-item');
		if (items.length < 2) return estimateTargetCount();

		const firstRect = items[0].getBoundingClientRect();
		const itemHeight = firstRect.height;
		if (itemHeight <= 0) return estimateTargetCount();

		let columns = 0;
		const firstTop = firstRect.top;
		for (let i = 0; i < items.length; i++) {
			const rect = items[i].getBoundingClientRect();
			if (Math.abs(rect.top - firstTop) < 5) {
				columns++;
			} else {
				break;
			}
		}
		if (columns === 0) columns = 1;

		const gap = getResponsiveGap();
		const viewportHeight = window.innerHeight;
		const rows = Math.max(1, Math.ceil(viewportHeight / (itemHeight + gap)));

		return columns * rows;
	}

	// ==================== 渲染 ====================

	function createPosterCard(show: TVShow, index: number, posterUrl: string | null): string {
		const translated = isTranslatedWork(show);
		const title = escapeHtml(show.name || show.originalName || '未知剧集');
		const workSlug = fuzzyFindWorkSlug(show.name || show.originalName || '');
		const href = workSlug ? `/${workSlug}` : '#';
		const placeholderUrl = posterUrl ? getLowQualityPosterUrl(show.posterPath) : null;

		return `
			<div class="poster-item" data-index="${index}" data-show-id="${show.id}">
				<a href="${href}" class="poster-link" title="${title}">
					<div class="poster-image-wrapper">
						${posterUrl ? `
							<div
								class="poster-bg"
								style="background-image: url('${placeholderUrl || posterUrl}');"
							></div>
							<img
								class="poster-img"
								data-src="${posterUrl}"
								alt="${title}"
								loading="lazy"
								decoding="async"
							/>
						` : `
							<div class="poster-placeholder">
								<span class="placeholder-text">${title.slice(0, 2)}</span>
							</div>
						`}
						<div class="poster-hover-overlay"></div>
						${translated ? `
							<div class="translated-badge">
								<img
									class="site-logo"
									src="/assets/logos/Atypical_W.svg"
									alt="已翻译"
									loading="lazy"
								/>
							</div>
						` : ''}
					</div>
				</a>
			</div>
		`;
	}

	function createSkeletons(count: number): string {
		return Array.from({ length: count }, (_, i) => `
			<div class="poster-item skeleton-item" data-index="${i}">
				<div class="poster-image-wrapper">
					<div class="skeleton-shimmer"></div>
				</div>
			</div>
		`).join('');
	}

	function renderPosters(count: number, animate = false): void {
		const showsToRender = allShows.slice(0, count);
		displayedCount = showsToRender.length;

		const cards = showsToRender.map((show, index) =>
			createPosterCard(show, index, posterUrlMap[show.id] || null)
		);
		gridEl.innerHTML = cards.join('');

		initLazyLoading();
		if (animate) animateEntrance();
	}

	function appendPosters(fromIndex: number, toIndex: number): void {
		const fragment = document.createDocumentFragment();
		const tempDiv = document.createElement('div');

		for (let i = fromIndex; i < toIndex && i < allShows.length; i++) {
			const show = allShows[i];
			const html = createPosterCard(show, i, posterUrlMap[show.id] || null);
			tempDiv.innerHTML = html;
			const item = tempDiv.firstElementChild as HTMLElement;
			if (item) {
				item.style.opacity = '0';
				item.style.transform = 'scale(0.95) translateY(10px)';
				fragment.appendChild(item);
			}
		}

		gridEl.appendChild(fragment);
		displayedCount = Math.min(toIndex, allShows.length);

		const newItems = gridEl.querySelectorAll<HTMLElement>(
			`.poster-item[data-index]:not(.skeleton-item)`
		);
		newItems.forEach((item) => {
			const idx = parseInt(item.dataset.index || '0');
			if (idx >= fromIndex) {
				requestAnimationFrame(() => {
					setTimeout(() => {
						item.style.transition = 'opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
						item.style.opacity = '1';
						item.style.transform = 'scale(1) translateY(0)';
					}, Math.min((idx - fromIndex) * CONFIG.entranceStaggerMs, CONFIG.entranceMaxDelay));
				});
			}
		});

		initLazyLoading();
	}

	// ==================== 懒加载 & 动画 ====================

	function initLazyLoading(): void {
		if (intersectionObserver) {
			intersectionObserver.disconnect();
		}

		intersectionObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const img = entry.target as HTMLImageElement;
						const src = img.dataset.src;
						if (src && !img.src) {
							img.src = src;
							img.onload = () => img.classList.add('loaded');
							img.onerror = () => img.classList.add('error');
						}
						intersectionObserver?.unobserve(img);
					}
				});
			},
			{
				rootMargin: CONFIG.lazyLoadRootMargin,
				threshold: 0.01,
			}
		);

		gridEl.querySelectorAll('img[data-src]:not([src])').forEach((img) => {
			intersectionObserver?.observe(img);
		});
	}

	function animateEntrance(): void {
		const items = gridEl.querySelectorAll<HTMLElement>('.poster-item:not(.skeleton-item)');
		items.forEach((item, index) => {
			item.style.opacity = '0';
			item.style.transform = 'scale(0.95) translateY(10px)';

			requestAnimationFrame(() => {
				setTimeout(() => {
					item.style.transition = 'opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
					item.style.opacity = '1';
					item.style.transform = 'scale(1) translateY(0)';
				}, Math.min(index * CONFIG.entranceStaggerMs, CONFIG.entranceMaxDelay));
			});
		});
	}

	// ==================== 缓存 ====================

	async function loadFromCache(): Promise<boolean> {
		const cache = posterWallCache.get();
		if (!cache || cache.shows.length === 0) return false;

		allShows = cache.shows;
		posterUrlMap = cache.posterUrls;

		return true;
	}

	function saveToCache(): void {
		if (allShows.length > 0 && Object.keys(posterUrlMap).length > 0) {
			posterWallCache.set(allShows, posterUrlMap);
		}
	}

	// ==================== 核心加载逻辑 ====================

	async function loadPosters(): Promise<void> {
		if (isLoading) return;
		isLoading = true;

		translatedTmdbIds = getTranslatedTmdbIds();

		const hasCache = await loadFromCache();

		const targetCount = estimateTargetCount();
		currentTargetCount = targetCount;

		if (hasCache && allShows.length >= targetCount) {
			renderPosters(targetCount, true);
			isLoading = false;
			setTimeout(() => refreshPostersSilently(), CONFIG.silentRefreshDelay);
			return;
		}

		const fetchCount = Math.max(targetCount + CONFIG.fetchBuffer, 60);
		gridEl.innerHTML = createSkeletons(Math.min(fetchCount, 60));
		errorEl.style.display = 'none';
		gridEl.style.display = 'grid';

		try {
			const fetchedShows = await getRandomPopularTVShows(fetchCount, CONFIG.initialMaxPages);

			if (fetchedShows.length === 0) {
				throw new Error('API_KEY_NOT_CONFIGURED');
			}

			allShows = fetchedShows.filter((show) => show.posterPath);

			if (allShows.length === 0) {
				throw new Error('NO_POSTER_DATA');
			}

			posterUrlMap = {};
			allShows.forEach((show) => {
				posterUrlMap[show.id] = getPosterUrl(show.posterPath);
			});

			saveToCache();

			const renderCount = Math.min(targetCount, allShows.length);
			renderPosters(renderCount, true);
			preloadVisibleImages();

			if (hasCache) {
				setTimeout(() => refreshPostersSilently(), CONFIG.silentRefreshDelay);
			}

		} catch (error) {
			console.error('Failed to load posters:', error);
			gridEl.style.display = 'none';
			errorEl.style.display = 'flex';

			const errorText = errorEl.querySelector('.error-text');
			if (errorText && error instanceof Error) {
				if (error.message === 'API_KEY_NOT_CONFIGURED') {
					errorText.textContent = 'TMDB API Key 未配置，请在 .env 文件中设置 PUBLIC_TMDB_API_KEY';
				} else if (error.message === 'NO_POSTER_DATA') {
					errorText.textContent = '未获取到有效的海报数据，请检查网络连接';
				}
			}
		} finally {
			isLoading = false;
		}
	}

	async function fetchMoreIfNeeded(needed: number): Promise<void> {
		if (isFetchingMore) return;
		if (allShows.length >= needed) return;

		isFetchingMore = true;
		const deficit = needed - allShows.length + CONFIG.fetchBuffer;
		const existingIds = new Set(allShows.map((s) => s.id));

		try {
			const newShows = await fetchAdditionalTVShows(existingIds, deficit);

			if (newShows.length > 0) {
				allShows = [...allShows, ...newShows];
				newShows.forEach((show) => {
					posterUrlMap[show.id] = getPosterUrl(show.posterPath);
				});
				saveToCache();
			}
		} catch (e) {
			console.warn('Failed to fetch additional shows:', e);
		} finally {
			isFetchingMore = false;
		}
	}

	async function adjustToViewport(): Promise<void> {
		if (gridEl.style.display === 'none') return;

		const targetCount = displayedCount > 2
			? measureActualTargetCount()
			: estimateTargetCount();

		if (targetCount === currentTargetCount && displayedCount >= targetCount) return;
		currentTargetCount = targetCount;

		if (targetCount <= displayedCount) {
			const items = gridEl.querySelectorAll('.poster-item');
			items.forEach((item, i) => {
				if (i < targetCount) {
					(item as HTMLElement).style.display = '';
				} else {
					(item as HTMLElement).style.display = 'none';
				}
			});
			displayedCount = targetCount;
			return;
		}

		if (allShows.length >= targetCount) {
			appendPosters(displayedCount, targetCount);
			return;
		}

		await fetchMoreIfNeeded(targetCount);

		if (displayedCount === 0) {
			renderPosters(Math.min(targetCount, allShows.length), true);
		} else {
			appendPosters(displayedCount, targetCount);
		}
	}

	async function refreshPostersSilently(): Promise<void> {
		if (isRefreshing) return;
		isRefreshing = true;

		try {
			const fetchCount = Math.max(currentTargetCount + CONFIG.fetchBuffer, 60);
			const fetchedShows = await getRandomPopularTVShows(fetchCount, CONFIG.initialMaxPages);

			if (fetchedShows.length === 0) return;

			const newShows = fetchedShows.filter((show) => show.posterPath);
			if (newShows.length === 0) return;

			const currentIds = new Set(allShows.map((s) => s.id));
			const hasChanges = newShows.some((s) => !currentIds.has(s.id));

			if (!hasChanges) return;

			allShows = newShows;
			posterUrlMap = {};
			allShows.forEach((show) => {
				posterUrlMap[show.id] = getPosterUrl(show.posterPath);
			});

			saveToCache();

			const renderCount = Math.min(currentTargetCount, allShows.length);

			gridEl.style.opacity = '0';
			setTimeout(() => {
				renderPosters(renderCount, false);
				gridEl.style.transition = 'opacity 0.5s ease';
				gridEl.style.opacity = '1';
			}, 300);

		} catch (e) {
			console.warn('Silent refresh failed:', e);
		} finally {
			isRefreshing = false;
		}
	}

	function preloadVisibleImages(): void {
		const viewportHeight = window.innerHeight;
		const images = gridEl.querySelectorAll<HTMLImageElement>('img[data-src]');
		const visibleSrcs: string[] = [];

		images.forEach((img) => {
			const rect = img.getBoundingClientRect();
			if (rect.top < viewportHeight * 1.5 && rect.bottom > -viewportHeight * 0.5) {
				const src = img.dataset.src;
				if (src) visibleSrcs.push(src);
			}
		});

		if (visibleSrcs.length > 0) {
			preloadImages(visibleSrcs, 8, 10000);
		}
	}

	// ==================== 事件监听 ====================

	retryBtn?.addEventListener('click', () => {
		posterWallCache.clear();
		allShows = [];
		displayedCount = 0;
		currentTargetCount = 0;
		loadPosters();
	});

	if (gridEl) {
		resizeObserver = new ResizeObserver(() => {
			clearTimeout(resizeDebounceTimer);
			resizeDebounceTimer = setTimeout(() => {
				adjustToViewport();
			}, CONFIG.resizeDebounceMs);
		});
		resizeObserver.observe(gridEl);
	}

	let resizeDebounceTimer: ReturnType<typeof setTimeout>;
	window.addEventListener('resize', () => {
		clearTimeout(resizeDebounceTimer);
		resizeDebounceTimer = setTimeout(() => {
			adjustToViewport();
		}, CONFIG.resizeDebounceMs);
	});

	document.addEventListener('visibilitychange', () => {
		if (document.visibilityState === 'visible' && allShows.length === 0) {
			loadPosters();
		}
	});

	if (gridEl) {
		loadPosters();
	}
</script>

<style>
	.poster-wall {
		width: 100%;
		height: 100vh;
		padding: 0;
		overflow: hidden;
		background: var(--sl-color-bg, #020617);
		box-sizing: border-box;
	}

	.wall-container {
		width: 100%;
		height: 100%;
		max-width: 100%;
		margin: 0 auto;
	}

	.poster-grid {
		width: 100%;
		height: 100%;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
		gap: 8px;
		padding: 8px;
		box-sizing: border-box;
		align-content: start;
	}

	.poster-item {
		position: relative;
		width: 100%;
		overflow: hidden;
		border-radius: var(--sl-radius-small, 8px);
		background: var(--sl-color-bg-sidebar, #0f172a);
		box-shadow: var(--shadow-sm, 0 1px 2px 0 rgb(0 0 0 / 0.3));
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.poster-link {
		display: block;
		width: 100%;
		height: 100%;
		text-decoration: none;
		position: relative;
	}

	.poster-image-wrapper {
		position: relative;
		width: 100%;
		height: 100%;
		aspect-ratio: 2 / 3;
		overflow: hidden;
		background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
	}

	.poster-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-size: cover;
		background-position: center top;
		background-repeat: no-repeat;
		filter: blur(8px) brightness(0.7);
		transform: scale(1.1);
		z-index: 0;
	}

	.poster-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		opacity: 0;
		transition: opacity 0.4s ease, transform 0.5s ease;
		display: block;
		position: relative;
		z-index: 1;
	}

	.poster-img.loaded {
		opacity: 1;
	}

	.poster-img.error {
		opacity: 0;
	}

	.poster-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.placeholder-text {
		color: #444;
		font-size: 24px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.poster-hover-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(255, 255, 255, 0);
		transition: background 0.35s ease;
		pointer-events: none;
		z-index: 2;
		border-radius: var(--sl-radius-small, 8px);
	}

	.poster-item:hover .poster-hover-overlay {
		background: rgba(255, 255, 255, 0.1);
	}

	.poster-item:hover {
		transform: translateY(-4px) scale(1.02);
		box-shadow: var(--shadow-xl, 0 20px 25px -5px rgb(0 0 0 / 0.5));
		z-index: 10;
	}

	.poster-item:hover .poster-img {
		transform: scale(1.05);
	}

	.translated-badge {
		position: absolute;
		bottom: 10px;
		right: 10px;
		width: 15%;
		min-width: 24px;
		max-width: 48px;
		z-index: 3;
		opacity: 0.7;
		pointer-events: none;
		transition: opacity 0.3s ease, transform 0.3s ease;
		filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.7));
	}

	.poster-item:hover .translated-badge {
		opacity: 1;
		transform: scale(1.15);
	}

	.site-logo {
		width: 100%;
		height: auto;
		display: block;
	}

	.skeleton-item {
		animation: pulse 1.5s ease-in-out infinite;
	}

	.skeleton-shimmer {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			90deg,
			var(--sl-color-bg-sidebar, #0f172a) 0%,
			var(--sl-color-bg-code, #0f172a) 50%,
			var(--sl-color-bg-sidebar, #0f172a) 100%
		);
		background-size: 200% 100%;
		animation: shimmer 1.5s infinite;
	}

	.wall-error {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 500px;
		padding: 40px;
	}

	.error-content {
		text-align: center;
		color: var(--sl-color-text-muted, #94a3b8);
		max-width: 400px;
	}

	.error-icon {
		width: 56px;
		height: 56px;
		margin-bottom: 20px;
		opacity: 0.6;
	}

	.error-text {
		font-size: 17px;
		line-height: 1.6;
		margin-bottom: 24px;
		color: var(--sl-color-text-muted, #94a3b8);
	}

	.retry-btn {
		padding: 12px 32px;
		background: var(--sl-color-accent, #2563eb);
		color: white;
		border: none;
		border-radius: var(--sl-radius-small, 8px);
		cursor: pointer;
		font-size: 15px;
		font-weight: 500;
		transition: all 0.25s ease;
		box-shadow: var(--shadow-glow, 0 0 20px rgba(37, 99, 235, 0.25));
