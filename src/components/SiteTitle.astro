---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
	<img
		class="logo-dark"
		alt="Atypical Fansub"
		src="/Atypical_W.svg"
		width="180"
		height="28"
	/>
	<img
		class="logo-light"
		alt="Atypical Fansub"
		src="/Atypical_B.svg"
		width="180"
		height="28"
	/>
</a>

<style>
	@layer starlight.core {
		.site-title {
			position: relative;
			align-items: center;
			gap: var(--sl-nav-gap);
			font-size: var(--sl-text-h4);
			font-weight: 600;
			color: var(--sl-color-text-accent);
			text-decoration: none;
			white-space: nowrap;
			min-width: 0;
		}

		.site-title img {
			height: 28px;
			width: auto;
			max-width: 100%;
			object-fit: contain;
			object-position: 0 50%;
			transition: opacity 0.5s var(--ease-out);
		}

		.logo-dark {
			opacity: 1;
		}

		.logo-light {
			opacity: 0;
			position: absolute;
			inset: 0;
			pointer-events: none;
		}

		:root[data-theme='light'] .logo-dark {
			opacity: 0;
			position: absolute;
			inset: 0;
			pointer-events: none;
		}

		:root[data-theme='light'] .logo-light {
			opacity: 1;
			position: relative;
			pointer-events: auto;
		}

		@media (max-width: 768px) {
			.site-title img {
				height: 20px;
			}
		}
	}
</style>
