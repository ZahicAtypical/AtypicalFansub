---
import config from 'virtual:starlight/user-config';

const currentLocale = Astro.locals.starlightRoute.locale;
const currentPath = Astro.url.pathname;

function getLocalePath(targetLocale: string): string {
	const base = import.meta.env.BASE_URL || '/';
	const cleanPath = currentPath.replace(base, '');
	const segments = cleanPath.split('/').filter(Boolean);
	const localeCodes = Object.keys(config.locales || {});
	const firstSegment = segments[0];
	const hasLocalePrefix = firstSegment && localeCodes.includes(firstSegment);

	if (targetLocale === 'root') {
		if (hasLocalePrefix) {
			segments.shift();
		}
		return base + segments.join('/') || base;
	}

	if (hasLocalePrefix) {
		segments[0] = targetLocale;
	} else {
		segments.unshift(targetLocale);
	}
	return base + segments.join('/');
}

const locales = Object.entries(config.locales || {}).map(([code, locale]) => ({
	code,
	label: locale?.label || code,
	href: getLocalePath(code),
	isCurrent: code === currentLocale,
}));
---

{
	locales.length > 1 && (
		<div class="lang-toggle-wrapper">
			<button class="lang-toggle" aria-label="Select language" type="button">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="10" />
					<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
					<path d="M2 12h20" />
				</svg>
			</button>
			<ul class="lang-dropdown" role="menu">
				{locales.map((locale) => (
					<li role="none">
						<a
							href={locale.href}
							role="menuitem"
							aria-current={locale.isCurrent ? 'page' : undefined}
							class={locale.isCurrent ? 'is-current' : ''}
						>
							{locale.label}
						</a>
					</li>
				))}
			</ul>
		</div>
	)
}

<style>
	.lang-toggle-wrapper {
		position: relative;
	}

	.lang-toggle {
		width: 36px;
		height: 36px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 8px;
		border: none;
		background: transparent;
		color: var(--sl-color-text-muted);
		cursor: pointer;
		transition:
			color 0.2s ease,
			background-color 0.2s ease;
		padding: 0;
	}

	.lang-toggle:hover,
	.lang-toggle-wrapper:hover .lang-toggle {
		color: var(--sl-color-text);
		background: rgba(148, 163, 184, 0.1);
	}

	.lang-dropdown {
		position: absolute;
		top: calc(100% + 6px);
		right: 0;
		min-width: 140px;
		padding: 6px;
		margin: 0;
		list-style: none;
		background: var(--sl-color-bg-nav);
		backdrop-filter: blur(16px) saturate(1.8);
		-webkit-backdrop-filter: blur(16px) saturate(1.8);
		border: 1px solid var(--sl-color-border);
		border-radius: 12px;
		box-shadow: var(--shadow-lg);
		opacity: 0;
		visibility: hidden;
		transform: translateY(-6px);
		transition:
			opacity 0.25s ease,
			transform 0.25s ease,
			visibility 0.25s ease;
		z-index: 100;
	}

	.lang-toggle-wrapper:hover .lang-dropdown,
	.lang-toggle-wrapper:focus-within .lang-dropdown {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.lang-dropdown li {
		margin: 0;
	}

	.lang-dropdown a {
		display: block;
		padding: 8px 12px;
		border-radius: 8px;
		color: var(--sl-color-text-muted);
		font-size: 0.875rem;
		text-decoration: none;
		transition:
			color 0.2s ease,
			background-color 0.2s ease;
		white-space: nowrap;
	}

	.lang-dropdown a:hover {
		color: var(--sl-color-text);
		background: rgba(148, 163, 184, 0.1);
	}

	.lang-dropdown a.is-current {
		color: var(--sl-color-accent-high);
		font-weight: 600;
	}
</style>
