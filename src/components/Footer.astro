---
/**
 * Footer 组件
 * 网站页脚，展示版权信息和导航链接
 * 支持响应式布局：宽屏显示完整版权+导航，窄屏显示精简版权并居中
 */
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-content">
		<!-- 左侧：版权信息（宽屏显示） -->
		<div class="footer-left">
			<span class="copyright-full">© {currentYear} AtypicalFansub 非典型字幕组</span>
		</div>

		<!-- 中间：精简版权信息（窄屏显示） -->
		<span class="copyright-short">© {currentYear} 非典型字幕组</span>

		<!-- 右侧：导航链接 -->
		<nav class="footer-right" aria-label="页脚导航">
			<a href="/guides/">使用教程</a>
			<a href="/about/">关于我们</a>
		</nav>
	</div>
</footer>

<style>
	/**
	### 1. Footer 高度变化的直接原因
Footer 的高度由以下因素决定：
- .site-footer 的 padding: var(--space-1)
- .footer-content 的 gap: var(--space-1)
- .copyright 的 font-size: 0.825rem + line-height: 1.2
- .footer-right a 的 font-size: 0.825rem + line-height: 1.2
	 * 页脚根元素
	 * 透明背景，与页面背景无缝融合
	 */
	.site-footer {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 100;
		height: inherit;
		padding: var(--space-1);
		transform: translateY(100%);
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		pointer-events: none;
		backdrop-filter: blur(4px) saturate(80%);
		-webkit-backdrop-filter: blur(4px) saturate(80%);
		background: rgba(15, 23, 42, 0.85);
	}

	.site-footer.is-visible {
		transform: translateY(0);
		pointer-events: auto; /* Allow interaction when visible */
	}

	/**
	 * 内容容器
	 * 使用 Flexbox 实现左右分布布局
	 */
	.footer-content {
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-1);
		padding: 0 var(--space-1);
		position: relative;
	}

	.copyright-full {
		color: var(--sl-color-text-muted);
		font-size: 0.75rem;
		line-height: 1.2;
		white-space: nowrap;
		flex-shrink: 0;
		display: flex;
		transition: 
			opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
			gap 0.4s cubic-bezier(0.4, 0, 0.2, 1);	
		vertical-align: middle;
		opacity: 1;
		max-width: 300px;
	}

	.footer-right {
		display: flex;
		gap: var(--space-2);
		align-items: center;
		transition:
			opacity 0.4s cubic-bezier(0.3, 0, 0.15, 1),
			gap 0.4s cubic-bezier(0.3, 0, 0.15, 1);
		overflow: hidden;
		flex-shrink: 0;
	}
	.footer-right a {
		color: var(--sl-color-text-muted);
		font-size: 0.75rem;
		text-decoration: none;
		transition: color 0.2s ease;
		line-height: 1.2;
		white-space: nowrap;
	}
	.footer-right a:hover {
		color: var(--sl-color-accent);
		scale: calc(1.02);
	}

	/* ========================================
	   精简版权文本（窄屏显示）
	   ======================================== */
	.copyright-short {
		color: var(--sl-color-text-muted);
		font-size: 0.75rem;
		line-height: 1.2;
		white-space: nowrap;
		flex-shrink: 0;
		display: none;
		transition: opacity 0.5s cubic-bezier(0.5, 0, 0.5, 1);
		transition-delay: 0.25s;
		vertical-align: middle;
		opacity: 0;
		max-width: 200px;
		pointer-events: none;
	}

	/* ========================================
	   响应式布局（容器查询）
	   ======================================== */

	/** 启用容器查询
	 * 基于 footer-content 的实际宽度进行响应式判断 */
	.footer-content {
		container-type: inline-size;
		container-name: footer;
	}

	/**
	 * 窄屏模式（容器宽度 ≤ 440px）
	 * - 完整版权文本渐隐
	 * - 精简版权文本从底部居中渐显
	 * - 隐藏导航链接 */
	@container footer (max-width: 440px) {
		/* 完整版权文本渐隐 */
		.copyright-full {
			opacity: 0;
			display: none;
			pointer-events: none;
		}

		/* 隐藏左侧容器，避免占用 flex 空间 */
		.footer-left {
			display: none;
		}

		/* 精简版权文本从底部居中渐显 */
		.copyright-short {
			opacity: 1;
			pointer-events: auto;
			display: flex;
			justify-content: center;
			margin: 0 auto;
		}

		/* 隐藏导航链接 */
		.footer-right {
			display: none;
		}
	}

	/**
	 * 宽屏模式（容器宽度 ≥ 441px）
	 * - 显示完整版权文本（左对齐）
	 * - 隐藏精简版权文本
	 * - 显示导航链接
	 */
	@container footer (min-width: 441px) {
		/* 恢复左右分布布局 */
		.footer-content {
			justify-content: space-between;
		}

		/* 显示完整版权文本 */
		.copyright-full {
			opacity: 1;
			pointer-events: auto;
		}

		/* 显示左侧容器 */
		.footer-left {
			display: flex;
		}
		
		.copyright-short {
			opacity: 0;
			pointer-events: none;
			display: none;
		}

		/* 显示导航链接 */
		.footer-right {
			opacity: 1;
			max-width: 200px;
			pointer-events: auto;
			flex: 0 0 auto;
			display: flex;
		}
	}
</style>

<script>
		document.addEventListener('DOMContentLoaded', () => {
			const footer = document.querySelector('.site-footer') as HTMLElement | null;
			if (!footer) return;

			let lastScrollY = window.scrollY;
			const scrollThreshold = 150;

			const handleScroll = () => {
				const currentScrollY = window.scrollY;
				const isScrollingDown = currentScrollY > lastScrollY;
				const isNearBottom = (window.innerHeight + currentScrollY) >= (document.documentElement.scrollHeight - scrollThreshold);

				if (isScrollingDown && isNearBottom) {
					footer.classList.add('is-visible');
				}

				lastScrollY = currentScrollY <= 0 ? 0 : currentScrollY;
			};

			// Check if the page is scrollable on load.
			const isScrollable = document.documentElement.scrollHeight > window.innerHeight;

			if (!isScrollable) {
				// If not scrollable, show the footer immediately.
				footer.classList.add('is-visible');
			} else {
				// If scrollable, set up the scroll listener.
				let scrollTimeout: number;

				window.addEventListener('scroll', () => {
					if (scrollTimeout) {
						window.clearTimeout(scrollTimeout);
					}
					scrollTimeout = window.setTimeout(handleScroll, 50);
				}, { passive: true });
			}
		});
	</script>

