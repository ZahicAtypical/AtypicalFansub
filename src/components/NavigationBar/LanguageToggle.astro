---
const currentPath = Astro.url.pathname;
const isEnglish = currentPath.startsWith('/en/');

function getLocalePath(targetLocale: string): string {
	if (targetLocale === 'en') {
		return currentPath;
	}
	if (isEnglish) return currentPath.replace(/^\/en/, '') || '/';
	return currentPath;
}

const locales = [
	{ code: 'root', label: '简中', href: getLocalePath('root'), isCurrent: true },
	{ code: 'en', label: 'En', href: getLocalePath('en'), isCurrent: false },
];
---

<div class="lang-toggle-wrapper">
	<button class="lang-toggle" aria-expanded="false" aria-haspopup="true" aria-label="Select language" type="button">
		<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="10" />
			<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
			<path d="M2 12h20" />
		</svg>
		<span class="lang-label">{locales.find(l => l.isCurrent)?.label || '简中'}</span>
	</button>
	<div class="lang-dropdown" role="menu">
		{locales.map(locale => (
			<a href={locale.href} role="menuitem" class={locale.isCurrent ? 'is-current' : ''}>
				{locale.label}
			</a>
		))}
	</div>
</div>

<script is:inline>
	(function() {
		const wrapper = document.querySelector('.lang-toggle-wrapper');
		const btn = document.querySelector('.lang-toggle');
		const dropdown = document.querySelector('.lang-dropdown');
		if (!wrapper || !btn || !dropdown) return;

		function toggleDropdown() {
			const isOpen = btn.getAttribute('aria-expanded') === 'true';
			btn.setAttribute('aria-expanded', !isOpen);
			dropdown.classList.toggle('is-open', !isOpen);
		}

		function closeDropdown() {
			btn.setAttribute('aria-expanded', 'false');
			dropdown.classList.remove('is-open');
		}

		btn.addEventListener('click', toggleDropdown);

		document.addEventListener('click', function(e) {
			if (!wrapper.contains(e.target)) {
				closeDropdown();
			}
		});

		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') closeDropdown();
		});
	})();
</script>

<style>
	.lang-toggle-wrapper {
		position: relative;
	}

	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 0.1rem;
		background: none;
		border: none;
		color: var(--sl-color-text);
		cursor: pointer;
		font-size: 0.875rem;
		border-radius: 0.5rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		min-width: 32px;
		height: 32px;
		justify-content: center;
		top: 0;
		right: 0;
		bottom: 0;
		left: 0;
	}

	.lang-toggle:hover {
		background: rgba(148, 163, 184, 0.1);
		transform: scale(1.05);
	}

	.lang-toggle:active {
		transform: translateY(0);
	}

	.lang-toggle svg {
		width: 24px;
		height: 24px;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.lang-toggle:hover svg {
		transform: rotate(180deg);
		color: var(--sl-color-accent);
	}

	.lang-label {
		display: none;
		font-weight: 500;
		font-size: 1rem;
		transition: color 0.3s ease;
	}

	.lang-toggle:hover .lang-label {
		color: var(--sl-color-accent);
	}

	@media (min-width: 768px) {
		.lang-label {
			display: inline;
		}
	}

	.lang-dropdown {
		display: none;
		position: absolute;
		top: calc(100% + 0.25rem);
		right: 0;
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-border);
		border-radius: var(--sl-radius-medium);
		padding: 0.5rem;
		min-width: 100px;
		box-shadow: var(--shadow-md);
		z-index: 200;
	}

	.lang-dropdown.is-open {
		display: block;
	}

	.lang-dropdown a {
		display: block;
		padding: 0.5rem;
		color: var(--sl-color-text);
		text-decoration: none;
		border-radius: var(--sl-radius-small);
		font-size: 0.875rem;
	}

	.lang-dropdown a:hover {
		background: var(--sl-color-bg-code);
	}

	.lang-dropdown a.is-current {
		color: var(--sl-color-accent);
		font-weight: 600;
	}
</style>
