---
const links = [
	{
		label: '哔哩哔哩',
		icon: 'bilibili',
		href: 'https://space.bilibili.com/3546843652819801',
	},
	{
		label: 'GitHub',
		icon: 'github',
		href: 'https://github.com/ZahicAtypical/AtypicalFansub',
	},
];
---

{
	links.length > 0 && (
		<nav class="social-icons" aria-label="Social media links">
			{links.map(({ label, href, icon }) => (
				<a
					href={href}
					target="_blank"
					rel="noopener noreferrer"
					class="social-link"
					aria-label={label}
				>
					{icon === 'bilibili' ? (
						<svg aria-hidden="true" class="social-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/>
						</svg>
					) : (
						<svg aria-hidden="true" class="social-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"/>
						</svg>
					)}
				</a>
			))}
		</nav>
	)
}

<style>
	.social-icons {
		display: flex;
		align-items: center;
		gap: 0.125rem;
	}

	.social-link {
		color: var(--sl-color-text);
		padding: 0.375rem;
		border-radius: 0.5rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 32px;
		height: 32px;
		position: relative;
		overflow: hidden;
	}

	.social-link:hover {
		color: var(--sl-color-accent);
		background: rgba(148, 163, 184, 0.08);
		transform: scale(1.05);
		border-color: rgba(148, 163, 184, 0.2);
	}

	.social-link:focus-visible {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
		border-radius: 0.5rem;
	}

	:root[data-theme='light'] .social-link:hover {
		color: var(--sl-color-accent);
		background: rgba(148, 163, 184, 0.05);
	}

	.social-icon {
		display: flex;
		width: 24px;
		height: 24px;
		position: relative;
		z-index: 1;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.social-link:hover .social-icon {
		transform: scale(1.1);
	}

	@media (max-width: 768px) {
		.social-link {
			width: 32px;
			height: 32px;	
		}

		.social-icon {
			width: 24px;
			height: 24px;
		}
	}

	@media (max-width: 600px) {
		.social-icons {
			display: none;
		}
	}
</style>