<a href="/" class="site-title">
	<img
		class="logo-dark"
		alt="Atypical Fansub"
		src="/Atypical_W.svg"
		width="120"
		height="22"
	/>
	<img
		class="logo-light"
		alt="Atypical Fansub"
		src="/Atypical_B.svg"
		width="120"
		height="22"
	/>
</a>

<style>
	.site-title {
		position: relative;
		display: inline-flex;
		align-items: center;
		width: 120px;
		height: 22px;
		color: var(--sl-color-text-accent);
		text-decoration: none;
		white-space: nowrap;
	}

	.site-title img {
		display: block;
		position: absolute;
		top: 0;
		left: 0;
		height: 22px;
		width: auto;
		max-width: 100%;
		object-fit: contain;
		object-position: 0 50%;
	}

	.logo-dark {
		opacity: 1;
	}

	.logo-light {
		opacity: 0;
	}

	:root[data-theme='light'] .logo-dark {
		opacity: 0;
	}

	:root[data-theme='light'] .logo-light {
		opacity: 1;
	}
</style>