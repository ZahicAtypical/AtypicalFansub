---
import BaseLayout from '../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const from = url.searchParams.get('from') || '';
const title = url.searchParams.get('title') || '';

let message = '抱歉，您访问的页面不存在';
if (from === 'poster' && title) {
	message = `作品「${title}」尚未收录到作品库中`;
}
---

<BaseLayout title="404 - 页面未找到">
	<section class="not-found">
		<div class="not-found-content">
			<h1>404</h1>
			<p class="not-found-message">{message}</p>

			{from === 'poster' && (
				<div class="suggestion-box">
					<p>您可以尝试以下操作：</p>
					<ul class="suggestion-list">
						<li>在作品库中浏览我们的全部作品</li>
						<li>使用搜索功能查找相关内容</li>
						<li>返回首页查看最新动态</li>
					</ul>
				</div>
			)}

			<div class="actions">
				<a href="/" class="btn-home">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
						<polyline points="9 22 9 12 15 12 15 22"/>
					</svg>
					返回首页
				</a>
				<a href="/works/" class="btn-secondary">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
					浏览作品库
				</a>
			</div>

			<div class="search-box">
				<form class="search-form" action="/works/" method="get" onsubmit="const q=this.querySelector('input[name=\'q\']').value.trim(); if(!q){return false;} return true;">
					<div class="search-input-wrapper">
						<svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"/>
							<line x1="21" y1="21" x2="16.65" y2="16.65"/>
						</svg>
						<input
							type="text"
							name="q"
							class="search-input"
							placeholder="搜索作品..."
							value={title}
							aria-label="搜索作品"
						/>
						<button type="submit" class="search-btn">搜索</button>
					</div>
				</form>
			</div>
		</div>
	</section>


</BaseLayout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		min-height: 70vh;
		padding: var(--space-16) var(--space-8);
	}

	.not-found-content {
		max-width: 520px;
		width: 100%;
	}

	.not-found h1 {
		font-size: clamp(4rem, 10vw, 8rem);
		font-weight: 800;
		color: var(--sl-color-accent);
		line-height: 1;
		margin-bottom: var(--space-4);
		opacity: 0.9;
	}

	.not-found-message {
		font-size: 1.25rem;
		color: var(--sl-color-text-muted);
		margin-bottom: var(--space-6);
		line-height: 1.6;
	}

	/* 建议框 */
	.suggestion-box {
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-border);
		border-radius: var(--sl-radius-medium);
		padding: var(--space-5);
		margin-bottom: var(--space-8);
		text-align: left;
	}

	.suggestion-box p {
		color: var(--sl-color-text);
		font-weight: 600;
		margin-bottom: var(--space-3);
		font-size: 0.9375rem;
	}

	.suggestion-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.suggestion-list li {
		color: var(--sl-color-text-muted);
		font-size: 0.875rem;
		padding: var(--space-1) 0;
		padding-left: var(--space-5);
		position: relative;
		line-height: 1.5;
	}

	.suggestion-list li::before {
		content: '→';
		position: absolute;
		left: 0;
		color: var(--sl-color-accent);
		font-weight: 600;
	}

	/* 操作按钮 */
	.actions {
		display: flex;
		gap: var(--space-3);
		justify-content: center;
		margin-bottom: var(--space-8);
		flex-wrap: wrap;
	}

	.btn-home,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: 0.875rem 1.75rem;
		border-radius: var(--sl-radius-full);
		font-weight: 600;
		font-size: 0.9375rem;
		text-decoration: none;
		transition: all 0.3s var(--ease-out);
		cursor: pointer;
		border: none;
	}

	.btn-home {
		background: linear-gradient(135deg, var(--sl-color-accent) 0%, var(--sl-color-accent-high) 100%);
		color: white;
		box-shadow: var(--shadow-glow);
	}

	.btn-home:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-glow-lg);
	}

	.btn-secondary {
		background: var(--sl-color-bg-sidebar);
		color: var(--sl-color-text);
		border: 1px solid var(--sl-color-border);
	}

	.btn-secondary:hover {
		background: var(--sl-color-bg-code);
		border-color: var(--sl-color-accent);
		transform: translateY(-2px);
	}

	/* 搜索框 */
	.search-box {
		width: 100%;
	}

	.search-form {
		width: 100%;
	}

	.search-input-wrapper {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		background: var(--sl-color-bg-sidebar);
		border: 1px solid var(--sl-color-border);
		border-radius: var(--sl-radius-full);
		padding: 0.5rem 0.5rem 0.5rem 1rem;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.search-input-wrapper:focus-within {
		border-color: var(--sl-color-accent);
		box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
	}

	.search-icon {
		color: var(--sl-color-text-hint);
		flex-shrink: 0;
	}

	.search-input {
		flex: 1;
		background: transparent;
		border: none;
		color: var(--sl-color-text);
		font-size: 0.9375rem;
		outline: none;
		padding: 0.25rem 0;
	}

	.search-input::placeholder {
		color: var(--sl-color-text-hint);
	}

	.search-btn {
		padding: 0.625rem 1.25rem;
		border-radius: var(--sl-radius-full);
		font-weight: 600;
		font-size: 0.875rem;
		background: var(--sl-color-accent);
		color: white;
		border: none;
		cursor: pointer;
		transition: all 0.2s ease;
		flex-shrink: 0;
	}

	.search-btn:hover {
		background: var(--sl-color-accent-high);
	}

	/* 响应式 */
	@media (max-width: 480px) {
		.actions {
			flex-direction: column;
			width: 100%;
		}

		.btn-home,
		.btn-secondary {
			width: 100%;
			justify-content: center;
		}

		.search-input-wrapper {
			padding: 0.375rem 0.375rem 0.375rem 0.75rem;
		}

		.search-btn {
			padding: 0.5rem 1rem;
		}
	}
</style>
